{
  "expo": {
    "name": "Neurovium",
    "slug": "neurovium-final",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "icon": "./assets/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#08070D"
      },
      "package": "com.anonymous.neuroviumfinal"
    },
    "web": {
      "bundler": "metro"
    }
  }
}
